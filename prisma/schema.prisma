// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Carrera {
  id         Int          @id @default(autoincrement())
  nombre     String
  materias   Materia[]
  estudiantes Estudiante[]
}

model Materia {
  id                    Int                    @id @default(autoincrement())
  nombre                String
  carreraId             Int
  carrera               Carrera                @relation(fields: [carreraId], references: [id])
  asignacionesLaboratorio AsignacionLaboratorio[]
}

model Ciclo {
  id                    Int                    @id @default(autoincrement())
  nombre                String
  activo                Boolean                @default(false)
  matriculas            Matricula[]
  asignacionesLugar     AsignacionLugar[]
  asignacionesLaboratorio AsignacionLaboratorio[]
}

model Estudiante {
  id         Int         @id @default(autoincrement())
  nombre     String
  carreraId  Int
  carrera    Carrera     @relation(fields: [carreraId], references: [id])
  matriculas Matricula[]
}

model Matricula {
  id           Int               @id @default(autoincrement())
  estudianteId Int
  cicloId      Int
  activo       Boolean           @default(true)
  estudiante   Estudiante        @relation(fields: [estudianteId], references: [id])
  ciclo        Ciclo             @relation(fields: [cicloId], references: [id])
  asignacionesLugar AsignacionLugar[]
}

model Laboratorio {
  id                    Int                    @id @default(autoincrement())
  nombre                String
  asignacionesLugar     AsignacionLugar[]
  asignacionesLaboratorio AsignacionLaboratorio[]
}

model AsignacionLugar {
  id           Int         @id @default(autoincrement())
  matriculaId  Int
  laboratorioId Int
  cicloId      Int
  matricula    Matricula   @relation(fields: [matriculaId], references: [id])
  laboratorio  Laboratorio @relation(fields: [laboratorioId], references: [id])
  ciclo        Ciclo       @relation(fields: [cicloId], references: [id])
}

model AsignacionLaboratorio {
  id            Int         @id @default(autoincrement())
  laboratorioId Int
  cicloId       Int
  materiaId     Int
  laboratorio   Laboratorio @relation(fields: [laboratorioId], references: [id])
  ciclo         Ciclo       @relation(fields: [cicloId], references: [id])
  materia       Materia     @relation(fields: [materiaId], references: [id])
}
